private List<Map<String, Object>> toPartitionOffsetList(List<TopicMessage> messages) {
    return messages.stream().map(message -> {
        Map<String, Object> map = new HashMap<>();
        map.put("partition", message.getPartition());
        map.put("offset", message.getOffset());
        return map;
    }).toList();
}


/* =====================================================================================
 * 4) KafkaConsumerService.java
 *    Assumes existing fields: consumerFactory, mapper, executorService, maxPollCount,
 *    initialTimeoutMs, incrementalTimeoutIncreaseMs, and helper getTopicPartitions(consumer, topic).
 * ===================================================================================== */

// ---- (a) sibling scan primitive: seek to startOffset, stop at endOffsetExclusive ----
/**
 * Processes a single Kafka partition starting at a given offset and stopping once the partition's
 * position reaches endOffsetExclusive (or the adaptive empty-poll loop completes). Mirrors
 * processPartition(...) but is bounded by an explicit offset range, for time-window features that
 * have already resolved per-partition start/end offsets via offsetsForTimes().
 *
 * @param tp                  partition to process
 * @param startOffset         offset to seek to (inclusive)
 * @param endOffsetExclusive  stop once position reaches this (exclusive); Long.MAX_VALUE for no bound
 * @param recordProcessor     applied to each polled batch, threading an accumulating result
 * @param initialResult       initial accumulator value
 */
private <T> T processPartitionInRange(TopicPartition tp,
                                      long startOffset,
                                      long endOffsetExclusive,
                                      BiFunction<ConsumerRecords<String, String>, T, T> recordProcessor,
                                      T initialResult) {

    T result = initialResult;

    try (KafkaConsumer<String, String> partitionConsumer =
                 (KafkaConsumer<String, String>) consumerFactory.createConsumer(
                         "-partition-range-info-" + tp.partition())) {

        partitionConsumer.assign(List.of(tp));
        partitionConsumer.seek(tp, startOffset);          // the one real difference vs processPartition

        int emptyPolls = 0;
        Duration pollTimeout = Duration.ofMillis(initialTimeoutMs);

        while (true) {
            ConsumerRecords<String, String> records = partitionConsumer.poll(pollTimeout);

            if (records.isEmpty()) {
                emptyPolls++;
                if (emptyPolls >= maxPollCount) break;
                pollTimeout = pollTimeout.plus(Duration.ofMillis(incrementalTimeoutIncreaseMs));
            } else {
                emptyPolls = 0;
                pollTimeout = Duration.ofMillis(initialTimeoutMs);
                result = recordProcessor.apply(records, result);
                if (partitionConsumer.position(tp) >= endOffsetExclusive) break;   // window end reached
            }
        }
    }
    return result;
}

// ---- (b) count by time range ----
/**
 * Counts messages in a topic between fromMillis and toMillis.
 * exact=false -> offset-span: sum of (endOffset - startOffset) per partition via offsetsForTimes(). Near-instant.
 *                On compacted topics this approximates writes, not surviving records.
 * exact=true  -> scans each partition from its start offset to its end offset and counts records.
 */
public TimeCountResult countMessagesByTimeRange(String topic, long fromMillis, long toMillis, boolean exact)
        throws ExecutionException, InterruptedException {

    TimeCountResult result = new TimeCountResult();
    result.setCountType(exact ? "EXACT_SCAN" : "OFFSET_SPAN");

    try (KafkaConsumer<String, String> consumer =
                 (KafkaConsumer<String, String>) consumerFactory.createConsumer("-time-count-info")) {

        List<TopicPartition> partitions = getTopicPartitions(consumer, topic);

        boolean compacted = isCompacted(topic);
        result.setCompacted(compacted);

        Map<TopicPartition, Long> startTsQuery = new HashMap<>();
        Map<TopicPartition, Long> endTsQuery = new HashMap<>();
        for (TopicPartition tp : partitions) {
            startTsQuery.put(tp, fromMillis);
            endTsQuery.put(tp, toMillis);
        }
        Map<TopicPartition, OffsetAndTimestamp> startOffsets = consumer.offsetsForTimes(startTsQuery);
        Map<TopicPartition, OffsetAndTimestamp> endOffsets   = consumer.offsetsForTimes(endTsQuery);
        Map<TopicPartition, Long> logEnd = consumer.endOffsets(partitions);

        long total = 0;
        Map<String, Long> perPartition = new HashMap<>();

        for (TopicPartition tp : partitions) {
            OffsetAndTimestamp startOat = startOffsets.get(tp);
            if (startOat == null) {                       // nothing after fromMillis on this partition
                perPartition.put("partition-" + tp.partition(), 0L);
                continue;
            }
            long startOffset = startOat.offset();

            OffsetAndTimestamp endOat = endOffsets.get(tp);
            long endOffset = (endOat != null) ? endOat.offset() : logEnd.get(tp);

            long span = Math.max(0, endOffset - startOffset);

            if (!exact) {
                perPartition.put("partition-" + tp.partition(), span);
                total += span;
            } else {
                long counted = processPartitionInRange(
                        tp, startOffset, endOffset,
                        (records, acc) -> acc + records.count(),
                        0L);
                perPartition.put("partition-" + tp.partition(), counted);
                total += counted;
            }
        }

        result.setCount(total);
        result.setPerPartition(perPartition);

        if (compacted && !exact) {
            result.setNote("Topic is compacted: count is the offset span in the window "
                    + "(approx. writes), not surviving records. Use exact=true for a true record count.");
        }
    }
    return result;
}

// ---- (c) text search by time range ----
/**
 * Finds messages whose raw value contains searchText (case-insensitive) between fromMillis and toMillis.
 * Seeks to the fromMillis offset per partition, scans to the toMillis offset, returns up to maxResults matches.
 */
public List<TopicMessage> searchByTextTimeRange(String topic, String searchText,
                                                long fromMillis, long toMillis, int maxResults)
        throws ExecutionException, InterruptedException {

    String needle = searchText.toLowerCase();

    try (KafkaConsumer<String, String> consumer =
                 (KafkaConsumer<String, String>) consumerFactory.createConsumer("-time-text-info")) {

        List<TopicPartition> partitions = getTopicPartitions(consumer, topic);

        Map<TopicPartition, Long> startTsQuery = new HashMap<>();
        Map<TopicPartition, Long> endTsQuery = new HashMap<>();
        for (TopicPartition tp : partitions) {
            startTsQuery.put(tp, fromMillis);
            endTsQuery.put(tp, toMillis);
        }
        Map<TopicPartition, OffsetAndTimestamp> startOffsets = consumer.offsetsForTimes(startTsQuery);
        Map<TopicPartition, OffsetAndTimestamp> endOffsets   = consumer.offsetsForTimes(endTsQuery);
        Map<TopicPartition, Long> logEnd = consumer.endOffsets(partitions);

        List<CompletableFuture<List<TopicMessage>>> futures = new ArrayList<>();

        for (TopicPartition tp : partitions) {
            OffsetAndTimestamp startOat = startOffsets.get(tp);
            if (startOat == null) {
                continue;                                  // nothing after fromMillis on this partition
            }
            long startOffset = startOat.offset();
            OffsetAndTimestamp endOat = endOffsets.get(tp);
            long endOffset = (endOat != null) ? endOat.offset() : logEnd.get(tp);

            futures.add(CompletableFuture.supplyAsync(() ->
                    processPartitionInRange(
                            tp, startOffset, endOffset,
                            (records, acc) -> {
                                for (ConsumerRecord<String, String> record : records) {
                                    if (record.timestamp() > toMillis) continue;   // timestamp guard (records not perfectly ordered)
                                    String value = record.value();
                                    if (value != null && value.toLowerCase().contains(needle)) {
                                        acc.add(new TopicMessage(
                                                record.partition(), record.offset(),
                                                record.key(), record.value(), record.timestamp()));
                                    }
                                }
                                return acc;
                            },
                            new ArrayList<TopicMessage>()),
                    executorService));
        }

        List<TopicMessage> allMatches = new ArrayList<>();
        for (CompletableFuture<List<TopicMessage>> future : futures) {
            allMatches.addAll(future.get());
        }
        // maxResults is a soft default for payload size, applied at the end
        if (allMatches.size() > maxResults) {
            return allMatches.subList(0, maxResults);
        }
        return allMatches;
    }
}

// ---- compaction detection via AdminClient describeConfigs ----
/**
 * Returns true if the topic's cleanup.policy includes "compact".
 * adminProps(): reuse however you already build admin/consumer config in this service.
 */
private boolean isCompacted(String topic) {
    try (Admin admin = Admin.create(adminProps())) {
        ConfigResource resource = new ConfigResource(ConfigResource.Type.TOPIC, topic);
        Config config = admin.describeConfigs(List.of(resource)).all().get().get(resource);
        ConfigEntry policy = config.get("cleanup.policy");
        return policy != null && policy.value() != null && policy.value().contains("compact");
    } catch (Exception e) {
        log.warn("Could not determine cleanup.policy for topic {}; assuming not compacted", topic, e);
        return false;
    }
}

