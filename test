// -------- Feature 1: count by time range --------
@PostMapping("/countMessagesByTimeRange/{topic}")
@Operation(
        summary = "Schedule a task to count messages in a topic within a time window",
        description = "Counts messages produced between fromTime and toTime. By default (exact=false) "
                + "this uses offset metadata (end-offset minus start-offset per partition) and is near-instant; "
                + "on compacted topics this counts offsets assigned in the window (approx. writes), not surviving "
                + "records. With exact=true it scans and counts the actual records in the window.")
@ApiResponses(value = {
        @ApiResponse(responseCode = "202", description = "Task scheduled successfully."),
        @ApiResponse(responseCode = "400", description = "Invalid request (missing or mis-ordered times)."),
        @ApiResponse(responseCode = "500", description = "Internal server error while scheduling the task."),
        @ApiResponse(responseCode = "503", description = "Task queue is full.")
})
public ResponseEntity<?> countMessagesByTimeRange(
        @Parameter(description = "Kafka topic to count") @PathVariable String topic,
        @io.swagger.v3.oas.annotations.parameters.RequestBody(
                content = @Content(examples = @ExampleObject(
                        name = "EST/EDT business-hours window",
                        value = """
                                {
                                  "fromTime": "2026-06-13T09:00:00-04:00",
                                  "toTime":   "2026-06-13T17:00:00-04:00",
                                  "exact":    false
                                }"""))
        )
        @RequestBody String requestBody) {

    UUID uuid = UUID.randomUUID();
    LogUtil.logTaskScheduled(uuid, Constants.COUNT_MESSAGES_BY_TIME_TASK, topic, null, requestBody);

    try {
        // --- light validation: times present, parseable, ordered ---
        JsonNode body = mapper.readTree(requestBody);
        long fromMillis = TimeUtil.toEpochMillis(body.path(Constants.FROM_TIME_PARAM).asText());
        long toMillis   = TimeUtil.toEpochMillis(body.path(Constants.TO_TIME_PARAM).asText());
        if (fromMillis >= toMillis) {
            return ResponseEntity.badRequest().body("fromTime must be before toTime.");
        }

        boolean taskAdded = taskQueue.offer(new KafkaTask(
                uuid.toString(), Constants.COUNT_MESSAGES_BY_TIME_TASK, topic, null, requestBody));

        if (taskAdded) {
            TaskCacheUtil.putNewTask(taskResultCache, uuid.toString(),
                    Constants.COUNT_MESSAGES_BY_TIME_TASK, topic, null, requestBody);
            log.info("/countMessagesByTimeRange task successfully scheduled.\n\ttaskId=" + uuid
                    + "\n\nVisit /ui/tasks for task status and results.");
            return ResponseEntity.accepted()
                    .header(HttpHeaders.LOCATION, "/ui/tasks")
                    .contentType(MediaType.TEXT_PLAIN)
                    .body("Task queued. taskId=" + uuid);
        } else {
            LogUtil.logTaskQueueFull(uuid, Constants.COUNT_MESSAGES_BY_TIME_TASK, topic, null, requestBody);
            return ResponseEntity.status(HttpStatus.SERVICE_UNAVAILABLE)
                    .body("Task queue is currently full. Please try again later.");
        }
    } catch (IllegalArgumentException ex) {           // bad/blank timestamp from TimeUtil
        return ResponseEntity.badRequest().body(ex.getMessage());
    } catch (Exception ex) {
        LogUtil.logTaskError(Constants.COUNT_MESSAGES_BY_TIME_TASK, topic, null, requestBody, ex);
        return ResponseEntity.status(HttpStatus.INTERNAL_SERVER_ERROR)
                .body("Error encountered while scheduling /countMessagesByTimeRange for topic '" + topic + "'.");
    }
}

