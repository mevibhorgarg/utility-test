/**
 * Executes a task to count messages in a topic within a time window. Window bounds
 * (fromTime/toTime as ISO-8601) and the exact flag are read from the task's request body.
 * exact=false -> offset-span count; exact=true -> scans and counts records in the window.
 */
private void executeCountMessagesByTimeTask(KafkaTask task)
        throws JsonProcessingException, ExecutionException, InterruptedException {

    String topic = task.getTaskParameters().get(Constants.TOPIC_PARAM);

    JsonNode body = mapper.readTree(task.getTaskParameters().get("requestBody"));
    long fromMillis = TimeUtil.toEpochMillis(body.path(Constants.FROM_TIME_PARAM).asText());
    long toMillis   = TimeUtil.toEpochMillis(body.path(Constants.TO_TIME_PARAM).asText());
    boolean exact   = body.path(Constants.EXACT_PARAM).asBoolean(false);

    long startTime = System.currentTimeMillis();
    KafkaConsumerService.TimeCountResult countResult =
            kafkaConsumerService.countMessagesByTimeRange(topic, fromMillis, toMillis, exact);
    long duration = System.currentTimeMillis() - startTime;

    Map<String, Object> metadata = createMetaDataMap(topic, duration);
    metadata.put(Constants.FROM_TIME_PARAM, body.path(Constants.FROM_TIME_PARAM).asText());
    metadata.put(Constants.TO_TIME_PARAM, body.path(Constants.TO_TIME_PARAM).asText());
    metadata.put(Constants.EXACT_PARAM, exact);

    Map<String, Object> responseData = new HashMap<>();
    responseData.put("messageCount", countResult.getCount());
    responseData.put("countType", countResult.getCountType());        // OFFSET_SPAN or EXACT_SCAN
    responseData.put("compacted", countResult.isCompacted());
    if (countResult.getNote() != null) {
        responseData.put("note", countResult.getNote());
    }
    responseData.put("perPartition", countResult.getPerPartition());

    cacheTaskResult(task.getTaskId(), metadata, responseData);
}

/**
 * Executes a task to search for messages whose raw value contains the given text fragment,
 * bounded to a time window. Stores matching partition/offset locations and execution duration.
 */
private void executeSearchByTextTimeTask(KafkaTask task)
        throws JsonProcessingException, ExecutionException, InterruptedException {

    String topic = task.getTaskParameters().get(Constants.TOPIC_PARAM);

    JsonNode body = mapper.readTree(task.getTaskParameters().get("requestBody"));
    String searchText = body.path(Constants.SEARCH_TEXT_PARAM).asText();
    long fromMillis = TimeUtil.toEpochMillis(body.path(Constants.FROM_TIME_PARAM).asText());
    long toMillis   = TimeUtil.toEpochMillis(body.path(Constants.TO_TIME_PARAM).asText());
    int maxResults  = body.path("maxResults").asInt(Constants.DEFAULT_MAX_RESULTS);

    long startTime = System.currentTimeMillis();
    List<TopicMessage> messages =
            kafkaConsumerService.searchByTextTimeRange(topic, searchText, fromMillis, toMillis, maxResults);
    long duration = System.currentTimeMillis() - startTime;

    Map<String, Object> metadata = createMetaDataMap(topic, duration);
    metadata.put(Constants.SEARCH_TEXT_PARAM, searchText);
    metadata.put(Constants.FROM_TIME_PARAM, body.path(Constants.FROM_TIME_PARAM).asText());
    metadata.put(Constants.TO_TIME_PARAM, body.path(Constants.TO_TIME_PARAM).asText());

    Map<String, Object> responseData = new HashMap<>();
    responseData.put("messageCount", messages.size());
    // We only care about the partitions and offsets for this task (same as JSON/text search)
    responseData.put("messages", toPartitionOffsetList(messages));    // <-- refactor helper
    cacheTaskResult(task.getTaskId(), metadata, responseData);
}

// ---- (c) refactor helper (your open to-do). Replace the duplicated stream/map block in
