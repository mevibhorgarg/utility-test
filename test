/* =====================================================================================
 * 5) TimeUtil.java
 *    Simple: require full ISO-8601 with offset. EDT=-04:00 (summer/now), EST=-05:00 (winter),
 *    IST=+05:30, UTC=Z. One parse line; the offset in the string carries the timezone.
 * ===================================================================================== */

public final class TimeUtil {

    private TimeUtil() {}

    /**
     * Parses an ISO-8601 timestamp that includes an offset (e.g. 2026-06-13T14:00:00-04:00,
     * ...+05:30, or ...Z) into epoch milliseconds for Kafka's offsetsForTimes().
     *
     * @throws IllegalArgumentException if the value is blank or not a valid offset datetime.
     */
    public static long toEpochMillis(String isoOffsetDateTime) {
        if (isoOffsetDateTime == null || isoOffsetDateTime.isBlank()) {
            throw new IllegalArgumentException(
                    "Timestamp is required (ISO-8601 with offset, e.g. 2026-06-13T14:00:00-04:00).");
        }
        try {
            return OffsetDateTime.parse(isoOffsetDateTime).toInstant().toEpochMilli();
        } catch (DateTimeParseException e) {
            throw new IllegalArgumentException(
                    "Invalid timestamp '" + isoOffsetDateTime + "'. Use ISO-8601 with offset, "
                  + "e.g. EST/EDT 2026-06-13T14:00:00-04:00, IST ...+05:30, UTC ...Z.", e);
        }
    }
}
